# ─────────────────────────────────────────────────────────────────
# The Moon Exports — Backend Environment Configuration
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.backend and set values for your environment.
# All variables have compile-time defaults in include/config.h.
# Environment variables override compile-time defaults at runtime.
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
# TME_PORT=3000

# ── CORS Origins ────────────────────────────────────────────────
# Production and development origins for CORS headers.
# TME_CORS_ORIGIN=https://www.themoonexports.com
# TME_CORS_ORIGIN_DEV=http://localhost:5000

# ── Logging ──────────────────────────────────────────────────────
# TME_LOG_LEVEL=info

# ── Database (Sprint 3) ─────────────────────────────────────────
# Path to the SQLite database file. Directory is created on startup.
# TME_DB_PATH=./data/tme.db

# ── Authentication (Sprint 2 — not yet implemented) ─────────────
# Required for admin endpoints once Sprint 2 ships.
# Currently unused; the server starts without these.
# TME_API_KEY=<your-secure-api-key-here>
# TME_JWT_SECRET=<your-jwt-secret-here>

# ── Email Notifications (Sprint 4) ──────────────────────────────
# SMTP settings for contact form email notifications.
# TME_SMTP_HOST=smtp.example.com
# TME_SMTP_PORT=587
# TME_SMTP_USER=notifications@themoonexports.com
# TME_SMTP_PASS=<smtp-password>
# TME_NOTIFY_EMAIL=admin@themoonexports.com
